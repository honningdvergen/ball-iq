# iOS native (Sprint #86 — Capacitor Phase 1)
# Pods/ is regenerated on every `pod install`; Podfile + Podfile.lock are the
# source of truth for native dependencies. xcuser* is per-developer Xcode
# state (window layouts, breakpoints) that shouldn't follow the project.
ios/App/Pods/
ios/App/build/
ios/build/
ios/DerivedData/
**/*.xcuserdata/
**/*.xcuserstate

# Signing keys — NEVER commit (Android keystore / Apple keys)
*.jks
*.keystore
*.p8
*.p12
key.properties

# Raw pg_dump lands here UNSCRUBBED (contains the service_role JWT inside the
# send_push trigger definition). Claude scrubs it into pg_dump-baseline.sql;
# the raw file must never be committable.
supabase/prod-snapshot/pg_dump-baseline.raw.sql
android/.idea/deploymentTargetSelector.xml
android/.idea/runConfigurations.xml
