{
  "appId": "app.balliq",
  "appName": "Ball IQ",
  "webDir": "dist",
  "_developmentTeam": "A99W5L256P",
  "_developmentTeamNote": "Apple Developer Team ID. Capacitor 6.x has no first-class teamId field; this entry is source-of-truth documentation. The actual value is applied to ios/App/App.xcodeproj/project.pbxproj (DEVELOPMENT_TEAM and CODE_SIGN_STYLE = Automatic) after `cap add ios`. If you regenerate the iOS project, re-apply.",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "never",
    "backgroundColor": "#0A0A0A",
    "limitsNavigationsToAppBoundDomains": false
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "launchAutoHide": false,
      "backgroundColor": "#0A0A0A",
      "androidScaleType": "CENTER_CROP",
      "iosSpinnerStyle": "small",
      "spinnerColor": "#58CC02",
      "splashImmersive": true,
      "splashFullScreen": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0A0A0A",
      "overlaysWebView": true
    },
    "Keyboard": {
      "resize": "none",
      "resizeOnFullScreen": true
    }
  }
}
